#!/bin/bash
# sim-debug — Run the game in the browser + debugger CLI in terminal
set -e
DIR="$(cd "$(dirname "$0")" && pwd)"
ELF="${1:?Usage: $0 <firmware.elf>}"

"$DIR/build/sim-core" --machine gameboy --firmware "$ELF" --debug 9001 \
    --chardev display=9004 --chardev usart2=9002 --chardev audio=9005 \
    --chardev trace=9003 --chardev io=9006 &
SIM_PID=$!

sleep 0.5
python3 "$DIR/src/sim-web/sim-web.py" --machine gameboy --firmware "$ELF" &
WEB_PID=$!

sleep 0.5
"$DIR/../dbg/build/sim-dbg" --connect localhost:9001 --elf "$ELF"

# When debugger exits, clean up
kill $WEB_PID $SIM_PID 2>/dev/null
wait $WEB_PID $SIM_PID 2>/dev/null
