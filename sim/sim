#!/bin/bash
# sim — ARM Cortex-M4 Emulator with Web Debugger
# Usage: ./sim <firmware.elf> [--machine <name>]
DIR="$(cd "$(dirname "$0")" && pwd)"
pkill -f sim-core 2>/dev/null
pkill -f sim-web 2>/dev/null
sleep 0.5

# If first arg doesn't start with --, treat it as --firmware
if [ -n "$1" ] && [ "${1:0:2}" != "--" ]; then
    FW="$1"; shift
    exec python3 "$DIR/src/sim-web/sim-web.py" --machine gameboy --firmware "$FW" "$@"
else
    exec python3 "$DIR/src/sim-web/sim-web.py" --machine gameboy "$@"
fi
