# RP2040 Pico configuration
# Cortex-M0+ with SMP (2 cores)

# Architecture
CONFIG_CPU_CORTEX_M4=n
CONFIG_CPU_CORTEX_M0PLUS=y
CONFIG_SMP=y
CONFIG_SMP_NUM_CPUS=2

# Drivers
CONFIG_UART=y
CONFIG_UART_PL011=y
CONFIG_GPIO=y
CONFIG_GPIO_RP2040=y
CONFIG_SPI=n
CONFIG_FLASH=n
CONFIG_GPIO_KEYS=n
CONFIG_GPIO_LEDS=n
CONFIG_CLOCK=y
CONFIG_CLOCK_RP2040=y

# Kernel
CONFIG_SCHED=y
CONFIG_SMP=y
CONFIG_SMP_NUM_CPUS=2
CONFIG_SYNC=y
CONFIG_MSGQ=y

# Libraries
CONFIG_HEAP=y
CONFIG_MEMSLAB=y
CONFIG_LOG=n
CONFIG_SHELL=y

# Filesystem
CONFIG_FS=n
CONFIG_TINYFS=n

# System
CONFIG_SYSTICK=y
