menu "Architecture"

config CPU_CORTEX_M4
    bool "ARM Cortex-M4"
    default y

config CPU_CORTEX_M0PLUS
    bool "ARM Cortex-M0+"
    default n

config SYSTICK
    bool "SysTick timer"
    default y

config MPU
    bool "MPU stack protection"
    default n
    depends on CPU_CORTEX_M4
    help
      Use the Memory Protection Unit to isolate task stacks.
      A task writing outside its stack triggers a MemManage fault.

config SMP
    bool "Symmetric multiprocessing"
    default n
    depends on CPU_CORTEX_M0PLUS

config SMP_NUM_CPUS
    int "Number of CPUs"
    default 1

endmenu
