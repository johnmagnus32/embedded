# STM32F411RE — full driver config

# Architecture
CONFIG_CPU_CORTEX_M4=y
CONFIG_CPU_CORTEX_M0PLUS=n
CONFIG_SMP=n
CONFIG_SMP_NUM_CPUS=1

# Drivers
CONFIG_CLOCK=y
CONFIG_CLOCK_STM32=y
CONFIG_CLOCK_RP2040=n
CONFIG_UART=y
CONFIG_UART_STM32=y
CONFIG_UART_PL011=n
CONFIG_GPIO=y
CONFIG_GPIO_STM32=y
CONFIG_GPIO_RP2040=n
CONFIG_SPI=y
CONFIG_SPI_STM32=y
CONFIG_FLASH=n
CONFIG_GPIO_KEYS=n
CONFIG_GPIO_LEDS=n
CONFIG_DISPLAY_ILI9341=y
CONFIG_I2S_STM32=y
CONFIG_ADC_STM32=y
CONFIG_INPUT_EXTI=y

# Kernel
CONFIG_SCHED=y
CONFIG_SYNC=y
CONFIG_MSGQ=n
CONFIG_SYSTICK=y

# Libraries
CONFIG_HEAP=y
CONFIG_MEMSLAB=n
CONFIG_LOG=n
CONFIG_SHELL=n

# Disabled
CONFIG_FS=n
CONFIG_TINYFS=n
CONFIG_MPU=n
CONFIG_USERSPACE=n
CONFIG_ELFLOADER=n
CONFIG_PM=n
