# simple-stm32 build configuration
# Like Zephyr's prj.conf / Linux's .config
# y = include, n = exclude

# Drivers
CONFIG_UART=y
CONFIG_GPIO=y
CONFIG_SPI=y
CONFIG_FLASH=y
CONFIG_GPIO_KEYS=y
CONFIG_GPIO_LEDS=y
CONFIG_CLOCK=y

# Kernel
CONFIG_SCHED=y
CONFIG_SYNC=y
CONFIG_MSGQ=y

# Libraries
CONFIG_HEAP=y
CONFIG_MEMSLAB=y
CONFIG_LOG=y

# Filesystem
CONFIG_FS=y
CONFIG_TINYFS=y

# System
CONFIG_SYSTICK=y
