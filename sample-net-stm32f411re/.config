# STM32F411RE + ENC28J60 Ethernet

CONFIG_CPU_CORTEX_M4=y
CONFIG_CPU_CORTEX_M0PLUS=n
CONFIG_SMP=n
CONFIG_SMP_NUM_CPUS=1

CONFIG_CLOCK=y
CONFIG_CLOCK_STM32=y
CONFIG_UART=y
CONFIG_UART_STM32=y
CONFIG_GPIO=y
CONFIG_GPIO_STM32=y
CONFIG_SPI=y
CONFIG_SPI_STM32=y

# Networking
CONFIG_NET=y
CONFIG_ETH_ENC28J60=y

# Kernel
CONFIG_SCHED=y
CONFIG_SYNC=y
CONFIG_MSGQ=n
CONFIG_SYSTICK=y

# Libraries
CONFIG_HEAP=y
CONFIG_MEMSLAB=n
CONFIG_SHELL=n

# Not needed
CONFIG_FLASH=n
CONFIG_GPIO_KEYS=n
CONFIG_GPIO_LEDS=n
CONFIG_FS=n
CONFIG_TINYFS=n
