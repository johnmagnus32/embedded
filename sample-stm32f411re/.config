# STM32F411RE Nucleo configuration

# Architecture
CONFIG_CPU_CORTEX_M4=y
CONFIG_CPU_CORTEX_M0PLUS=n
CONFIG_SMP=n
CONFIG_SMP_NUM_CPUS=1

# Drivers (STM32-specific)
CONFIG_CLOCK=y
CONFIG_CLOCK_STM32=y
CONFIG_CLOCK_RP2040=n
CONFIG_UART=y
CONFIG_UART_STM32=y
CONFIG_UART_PL011=n
CONFIG_GPIO=y
CONFIG_GPIO_STM32=y
CONFIG_GPIO_RP2040=n
CONFIG_SPI=y
CONFIG_SPI_STM32=y
CONFIG_FLASH=y
CONFIG_GPIO_KEYS=y
CONFIG_GPIO_LEDS=y

# Kernel
CONFIG_SCHED=y
CONFIG_SYNC=y
CONFIG_MSGQ=y
CONFIG_SYSTICK=y

# Libraries
CONFIG_HEAP=y
CONFIG_MEMSLAB=y
CONFIG_LOG=n
CONFIG_SHELL=y

# Filesystem
CONFIG_FS=y
CONFIG_TINYFS=y
