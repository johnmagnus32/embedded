#!/bin/bash
set -e

# Get list of staged files
STAGED=$(git diff --cached --name-only)

SIM_CHANGED=0
OS_CHANGED=0
FW_CHANGED=0

for f in $STAGED; do
    case "$f" in
        sim/*) SIM_CHANGED=1 ;;
        os/*)  OS_CHANGED=1 ;;
        projects/*) FW_CHANGED=1 ;;
    esac
done

if [ "$SIM_CHANGED" -eq 1 ]; then
    echo "=== sim changed: building ==="
    make -C sim
    echo "=== sim changed: running tests ==="
    python3 sim/tests/run_tests.py
fi

if [ "$OS_CHANGED" -eq 1 ] || [ "$FW_CHANGED" -eq 1 ]; then
    echo "=== os/firmware changed: building firmware ==="
    make -C projects/gameboy
fi

if [ "$OS_CHANGED" -eq 1 ]; then
    echo "=== os changed: running sim tests (OS affects emulated firmware) ==="
    python3 sim/tests/run_tests.py
fi

echo "=== Pre-commit checks passed ==="
