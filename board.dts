/*
 * STM32F411RE Nucleo board device tree
 *
 * This is a simplified version of what Zephyr uses in:
 *   zephyr/dts/arm/st/f4/stm32f411Xe.dtsi
 *   zephyr/boards/st/nucleo_f411re/nucleo_f411re.dts
 */

/ {
    compatible = "st,nucleo-f411re";
    model = "STM32F411RE Nucleo";

    clocks {
        hsi: hsi {
            compatible = "fixed-clock";
            clock-frequency = <16000000>;
        };
    };

    soc {
        compatible = "st,stm32f411";

        rcc: rcc@40023800 {
            compatible = "st,stm32-rcc";
            reg = <0x40023800>;
        };

        gpioa: gpio@40020000 {
            compatible = "st,stm32-gpio";
            reg = <0x40020000>;
            clocks = <&rcc 0 0>;  /* AHB1, bit 0 */
        };

        gpioc: gpio@40020800 {
            compatible = "st,stm32-gpio";
            reg = <0x40020800>;
            clocks = <&rcc 0 2>;  /* AHB1, bit 2 */
        };

        usart2: serial@40004400 {
            compatible = "st,stm32-usart";
            reg = <0x40004400>;
            clocks = <&rcc 1 17>;  /* APB1, bit 17 */
            tx-pin = <2>;
            tx-af = <7>;
            tx-port = <&gpioa>;
            baudrate = <115200>;
            status = "okay";
        };
    };

    buttons: buttons {
        compatible = "gpio-keys";
        gpio-port = <&gpioc>;
        /* pin numbers for each button (active low, internal pull-up) */
        pin-up = <0>;
        pin-down = <1>;
        pin-left = <2>;
        pin-right = <3>;
        pin-a = <4>;
        pin-b = <5>;
        status = "okay";
    };

    chosen {
        console = <&usart2>;
    };
};
